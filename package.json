{
  "name": "txukun",
  "version": "1.5.1",
  "private": true,
  "description": "Euskarazko testu zuzentzailea — Basque text correction tool",
  "homepage": "https://itzune.eus/txukun/",
  "type": "module",
  "scripts": {
    "predev": "npm run copy-dicts",
    "dev": "vite",
    "build": "npm run copy-dicts && vite build",
    "postinstall": "npm run copy-dicts",
    "copy-dicts": "mkdir -p public/dicts && cp node_modules/dictionary-eu/index.aff public/dicts/eu.aff && cp node_modules/dictionary-eu/index.dic public/dicts/eu.dic",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@huggingface/transformers": "^3.6.0",
    "dictionary-eu": "^4.0.0",
    "hunspell-asm": "^4.0.2",
    "idaztian": "file:../../xezpeleta/Idaztian/packages/idaztian",
    "nspell": "^2.1.5"
  },
  "devDependencies": {
    "gh-pages": "^6.0.0",
    "vite": "^5.0.0"
  }
}
